function formatTanggal(tanggal){

  if(!tanggal) return "-";

  let tgl = new Date(tanggal);

  return tgl.toLocaleDateString("id-ID",{
    day:"2-digit",
    month:"2-digit",
    year:"numeric"
  });

}
function bersihkanAngka(value){

  if(value == null || value == ""){
    return "";
  }

  // jika format ISO date
  if(
    typeof value === "string" &&
    value.includes("T")
  ){
    return "";
  }

  return value;

}

function formatNumberField(value){

  if(value == null || value == ""){
    return "";
  }

  // =========================
  // JIKA DATE OBJECT
  // =========================

  if(value instanceof Date){

    return "";

  }

  // =========================
  // JIKA STRING ISO DATE
  // =========================

  if(
    typeof value === "string" &&
    value.includes("T")
  ){

    return "";

  }

  return value;

}


