/* =========================
FORGOT PASSWORD PREMIUM
========================= */

.forgot-box{
  margin-top:18px;
  text-align:center;
}

.forgot-password-btn{

  background:linear-gradient(
    135deg,
    #2563eb,
    #1d4ed8
  ) !important;

  color:white !important;

  border:none;

  width:100%;

  padding:12px;

  border-radius:12px;

  font-size:13px;

  font-weight:700;

  cursor:pointer;

  box-shadow:
    0 4px 12px rgba(37,99,235,0.25);

  transition:0.25s;
}

.forgot-password-btn:hover{

  transform:translateY(-2px);

  box-shadow:
    0 8px 18px rgba(37,99,235,0.35);

}

.forgot-box small{

  display:block;

  margin-top:8px;

  color:#64748b;

  font-size:11px;

}


/* =========================
SHOW PASSWORD
========================= */

.password-wrapper{
  position:relative;
}

.password-wrapper input{
  padding-right:50px;
}

.toggle-password{
  position:absolute;
  right:8px;
  top:50%;
  transform:translateY(-50%);
  border:none;
  background:transparent;
  cursor:pointer;
  font-size:20px;
  padding:4px;
  color:#64748b;
}

.toggle-password:hover{
  color:#2563eb;
}

/* =========================
USER INFO & LOGOUT BUTTON 
========================= */

.header {
  position: relative;
}

/* Wrapper penampung profil dan tombol logout */
.user-meta-wrapper {
  position: absolute;
  top: 14px;
  right: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  z-index: 999;
}

/* Komponen Profil Minimalis */
.user-profile {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(255, 255, 255, 0.1);
  padding: 4px 14px 4px 5px; /* Padding kanan disesuaikan agar seimbang */
  border-radius: 20px;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.15);
}

/* Avatar Lingkaran Berisi Inisial */
.user-avatar {
  width: 28px;
  height: 28px;
  background: white;
  color: #1d4ed8; /* Menyesuaikan warna tema utama aplikasi */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 800;
  box-shadow: 0 2px 6px rgba(0,0,0,0.1);
}

/* Text Info di Sebelah Avatar */
.user-info {
  display: flex;
  align-items: center; /* Membuat teks nama sejajar sempurna di tengah avatar */
}

.user-name {
  font-size: 13px;
  font-weight: 700;
  color: white;
  line-height: 1;
  white-space: nowrap; /* Mencegah nama terpotong ke bawah */
}

/* Modifikasi Tombol Logout agar Selaras */
.logout-btn {
  border: none;
  background: rgba(255, 255, 255, 0.18);
  color: white;
  padding: 8px 14px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  transition: 0.2s;
}

.logout-btn:hover {
  background: rgba(255, 255, 255, 0.28);
  transform: scale(1.03);
}

/* Penyesuaian Responsif untuk Perangkat Mobile */
@media screen and (max-width: 768px) {
  .user-meta-wrapper {
    top: 10px;
    right: 10px;
    gap: 6px;
  }
  
  .user-profile {
    padding: 3px 3px 3px 3px; /* Mengubah padding menjadi lingkaran penuh di mobile */
  }
  
  .user-avatar {
    width: 26px;
    height: 26px;
    font-size: 10px;
  }
  
  .user-info {
    display: none; /* Menyembunyikan nama di mobile agar ruang navbar tetap lega */
  }

  .logout-btn {
    padding: 6px 12px;
    font-size: 11px;
  }
