// Fungsi pembantu pembuat Device ID Unik di Browser Pengguna
function dapatkanAtauBuatDeviceID() {
  let deviceId = localStorage.getItem("perfusionist_device_id");
  if (!deviceId) {
    // Membuat string acak penanda unik browser perangkat
    deviceId = 'DEV-' + Math.random().toString(36).substring(2, 11).toUpperCase() + '-' + Date.now().toString(36).toUpperCase();
    localStorage.setItem("perfusionist_device_id", deviceId);
  }
  return deviceId;
}

async function cekDeviceSaatAwal(){

  const deviceId = dapatkanAtauBuatDeviceID();

  try{

    const response = await fetch(SCRIPT_URL,{
      method:"POST",
      body:JSON.stringify({
        mode:"cekDevice",
        deviceId:deviceId
      })
    });

    const result = await response.json();

    const registerBtn =
      document.getElementById("registerBtn");

    if(result.registered){

      registerBtn.style.display = "none";

      document.getElementById(
        "authActionContainer"
      ).style.display = "flex";

    }
    
    else{

  registerBtn.style.display = "block";

  document.getElementById(
    "authActionContainer"
  ).style.display = "none";

}

  }catch(error){

    console.error(error);

    alert("Gagal mengecek status perangkat");

  }

}

// Fungsi utama Register Akun
function registerUser() {
  // Ambil data input dari form register Anda
  const usernameInput = document.getElementById("regUsername") || document.getElementById("username");
  const passwordInput = document.getElementById("regPassword") || document.getElementById("password");
  
  if (!usernameInput || !passwordInput) {
    tampilkanToast("Sistem Error", "Elemen Form Input tidak ditemukan di HTML.");
    return;
  }

  const userTxt = usernameInput.value.trim();
  const passTxt = passwordInput.value.trim();

  if (!userTxt || !passTxt) {
    tampilkanToast("Registrasi Gagal", "Username dan Password tidak boleh kosong!");
    return;
  }

  // Generate / ambil Device ID unik dari browser perangkat
  const deviceID = dapatkanAtauBuatDeviceID();

  // Susun payload objek data dengan parameter 'mode: "register"' sesuai doPost server
  const payloadData = {
    mode: "register",
    username: userTxt,
    password: passTxt,
    deviceId: deviceID
  };

  tampilkanToast("Memproses", "Sedang mendaftarkan akun dan mengunci Device ID...");

  // Kirim data menggunakan metode POST dengan isi JSON String ke URL Apps Script Anda
  fetch(SCRIPT_URL, {
    method: "POST",
    body: JSON.stringify(payloadData)
  })
  .then(response => {
    if (!response.ok) {
      throw new Error("Jaringan bermasalah atau URL Script salah.");
    }
    return response.text();
  })
  .then(responseText => {
    // Membaca teks return dari blok doPost
    if (responseText === "Register berhasil") {

        tampilkanToast(
          "Sukses",
          "Registrasi Berhasil!"
        );

        document.getElementById("registerBtn").style.display = "none";

        document.getElementById(
          "authActionContainer"
        ).style.display = "flex";

        usernameInput.value = "";
        passwordInput.value = "";

    } else {
      
      tampilkanToast("Registrasi Ditolak", responseText);
    }
  })
  .catch(error => {
    console.error(error);
    tampilkanToast("Koneksi Error", "Gagal menghubungi server database.");
  });
}

