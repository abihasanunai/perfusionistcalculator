  let faktorEBV = 0;

  if(bb < 10){
    faktorEBV = 80;
  }
  else if(bb < 21){
    faktorEBV = 75;
  }
  else if(bb < 31){
    faktorEBV = 70;
  }
  else if(bb < 41){
    faktorEBV = 65;
  }
  else{
    faktorEBV = 60;
  }

  let ebv = bb * faktorEBV;

  document.getElementById("hasilEBV").innerHTML =
    "EBV : " + ebv.toFixed(0) + " mL";

