// Fungsi pembantu untuk memicu notifikasi Toast bawaan kode Anda
function tampilkanToast(title, message) {
  const toast = document.getElementById("toastNotif");
  document.getElementById("toastTitle").innerText = title;
  document.getElementById("toastMessage").innerText = message;
  toast.classList.add("show");
  setTimeout(() => {
    toast.classList.remove("show");
  }, 3000);
}

// Fungsi untuk membuat/mengambil Device ID unik dari perangkat browser
function getOrCreateDeviceID() {
  let deviceID = localStorage.getItem("app_device_id");
  if (!deviceID) {
    // Membuat ID acak unik jika perangkat belum memilikinya
    deviceID = 'DEV-' + Math.random().toString(36).substring(2, 11).toUpperCase() + '-' + Date.now();
    localStorage.setItem("app_device_id", deviceID);
  }
  return deviceID;
}

